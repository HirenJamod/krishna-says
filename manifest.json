{
  "id": "krishna-says-pwa",
  "name": "Krishna Says",
  "short_name": "Krishna",
  "description": "AI-powered spiritual guidance inspired by timeless wisdom of the Bhagavad Gita.",
  "start_url": "./index.html",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone"],
  "orientation": "portrait",
  "background_color": "#F5F5F7",
  "theme_color": "#D4AF37",
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "",
  "scope_extensions": [],
  "categories": ["lifestyle", "education"],
  "note_taking": {
    "new_note_url": "./index.html#chat"
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+wisdom",
      "url": "./index.html?wisdom=%s"
    }
  ],
  "icons": [
    {
      "src": "./assets/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./assets/icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./assets/icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./assets/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "./assets/icons/icon-512.jpg",
      "sizes": "512x512",
      "type": "image/jpeg",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "./assets/screenshots/desktop.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Desktop view of Krishna Says"
    },
    {
      "src": "./assets/screenshots/mobile.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Mobile view of Krishna Says"
    }
  ],
  "shortcuts": [
    {
      "name": "Ask Wisdom",
      "short_name": "Ask",
      "description": "Go directly to the chat",
      "url": "./index.html#chat",
      "icons": [{ "src": "./assets/icons/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "widgets": []
}
