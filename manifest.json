{
  "id": "krishna-says-pwa",
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+wisdom",
      "url": "./index.html?wisdom=%s"
    }
  ],
  "name": "Krishna Says",
  "short_name": "Krishna",
  "description": "AI-powered spiritual guidance inspired by timeless wisdom of the Bhagavad Gita.",
  "start_url": "./index.html",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#F5F5F7",
  "theme_color": "#D4AF37",
  "categories": ["lifestyle", "education"],
  "icons": [
    {
      "src": "./assets/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/jpeg",
      "purpose": "any"
    },
    {
      "src": "./assets/icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/jpeg",
      "purpose": "any"
    },
    {
      "src": "./assets/icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/jpeg",
      "purpose": "any"
    },
    {
      "src": "./assets/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/jpeg",
      "purpose": "maskable any"
    },
    {
      "src": "./assets/icons/icon-512.jpg",
      "sizes": "512x512",
      "type": "image/jpeg",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "./assets/screenshots/desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop view of Krishna Says"
    },
    {
      "src": "./assets/screenshots/mobile.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile view of Krishna Says"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "text/plain": [".txt"],
        "application/json": [".json"]
      },
      "icons": [
        {
          "src": "./assets/icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/jpeg"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "shortcuts": [
    {
      "name": "Ask Wisdom",
      "short_name": "Ask",
      "description": "Go directly to the chat",
      "url": "./index.html#chat",
      "icons": [{ "src": "./assets/icons/icon-96.png", "sizes": "96x96", "type": "image/jpeg" }]
    }
  ]
}
